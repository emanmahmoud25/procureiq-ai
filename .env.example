# Copy this file to .env and fill in your keys
GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
AGENTOPS_API_KEY=your_agentops_api_key_here
database_url: str = postgresql://procurement:procurement123@localhost:5432/procurement_db

# Agent configuration
TOP_PICKS=5
SCORE_THRESHOLD=0.15
# The default country and language settings for the agent. These can be overridden by user input or other configurations.
DEFAULT_COUNTRY=Egypt
DEFAULT_LANGUAGE=English
max_results_per_query= 10

# The default list of websites to search for products. This can be overridden by user input or other configurations.
target_sites=["amazon.eg", "jumia.com.eg", "noon.com", "carrefouregypt.com", "extra.com.eg"]
# Model configuration
GROQ_MODEL=llama-3.1-8b-instant
TEMPERATURE=0.2
MAX_TOKENS=300
# Search configuration
SEARCH_DELAY=1.5
PRICE_SEARCH_DELAY=1.0
IMAGE_SEARCH_DELAY=0.5
# Output configuration  
OUTPUT_DIR=./output

